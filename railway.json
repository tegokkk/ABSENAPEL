{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watch": ["backend/**"],
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20", "sqlite"]
        },
        "install": {
          "cmds": ["cd backend && npm install"]
        },
        "build": {
          "cmds": ["cd backend && npm run build"]
        }
      },
      "start": {
        "cmd": "cd backend && npm start"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
