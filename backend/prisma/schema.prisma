// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  username    String       @unique
  password    String
  role        String       @default("MAHASISWA") // ADMIN or MAHASISWA
  name        String
  npm         String?      @unique
  kelas       String?      // e.g., "MI 4A", "MI 4B", null for ADMIN
  attendances Attendance[]
}

model Attendance {
  id_absensi       Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id])
  tanggal          DateTime  @default(now())
  jam_absen        DateTime  @default(now())
  status           String    // 'HADIR', 'TERLAMBAT', 'PENDING'
  latitude         Float
  longitude        Float
  alamat_lokasi    String?
  device_info      String?
  ip_address       String?
  foto_selfie      String?
  // === Anti-Fake GPS Fields ===
  accuracy         Float?    // GPS accuracy dalam meter
  gps_timestamp    Float?    // Timestamp GPS dari device (ms since epoch)
  jarak_dari_titik Float?    // Jarak user dari titik apel (meter)
  browser          String?   // Nama browser
  platform         String?   // Platform/OS (Android, iOS, Windows, dll)
  validasi_lokasi  String    @default("VALID") // VALID, DI_LUAR_RADIUS, GPS_TIDAK_AKURAT, LOKASI_MENCURIGAKAN, KEMUNGKINAN_FAKE_GPS, PENDING_VERIFIKASI
  alasan_flag      String?   // Alasan detail kenapa dicurigai (comma-separated flags)
  admin_action     String?   // APPROVED / REJECTED / null
  admin_note       String?   // Catatan admin saat approve/reject
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
